{
  "expo": {
    "name": "Task Tracker",
    "slug": "task-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tasktracker.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F9FAFB"
      },
      "package": "com.tasktracker.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "task-tracker"
  }
}
